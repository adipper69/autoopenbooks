// Parse line extracts data from a single line
func parseLine(line string) (BookDetail, error) {
	var book BookDetail
	book.Full = line

	// Get Server
	firstSpace := strings.Index(line, " ")
	if firstSpace == -1 {
		return BookDetail{}, errors.New("could not parse server")
	}
	book.Server = line[1:firstSpace] // Skip the "!"
	rest := line[firstSpace+1:]

	infoIdx := strings.LastIndex(rest, " ::INFO::")
	book.Size = "N/A"
	if infoIdx != -1 {
		sizeStr := strings.TrimSpace(rest[infoIdx+len(" ::INFO::"):])
		book.Size = strings.Split(sizeStr, " ")[0]
		book.Full = line[:firstSpace+1+infoIdx]
		rest = strings.TrimSpace(rest[:infoIdx])
	}

	// Get the Title
	restLower := strings.ToLower(rest)
	foundExt := false
	for _, ext := range fileTypes { //Loop through each possible file extension we've got on record
		endTitle := strings.LastIndex(restLower, "."+ext) // check if it contains our extension
		if endTitle == -1 || endTitle != len(rest)-len(ext)-1 {
			continue
		}
		book.Format = ext
		if ext == "rar" || ext == "zip" { // If the extension is .rar or .zip the actual format is contained in ()
			for _, ext2 := range fileTypes[:len(fileTypes)-2] { // Range over the eBook formats (exclude archives)
				if strings.Contains(restLower[:endTitle], ext2) {
					book.Format = ext2
				}
			}
		}
		dashIdx := strings.Index(rest, " - ")
		if dashIdx == -1 {
			book.Author = ""
			book.Title = rest[:endTitle]
		} else {
			book.Author = rest[:dashIdx]
			if strings.Contains(book.Author, "%") {
				parts := strings.SplitN(book.Author, " ", 2)
				if len(parts) == 2 {
					book.Author = parts[1]
				}
			}
			book.Title = rest[dashIdx+len(" - ") : endTitle]
		}
		foundExt = true
		break
	}

	if !foundExt { // Got through the entire loop without finding a single match
		return BookDetail{}, errors.New("could not parse title")
	}

	return book, nil
}
